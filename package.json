{
  "name": "petro-world-backend",
  "version": "1.0.0",
  "description": "PetroWorld E-Commerce Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:reset": "ts-node -e \"require('./src/config/database').pool.query(require('fs').readFileSync('./db/seed.sql','utf8')).then(()=>process.exit())\""
  },
  "dependencies": {
    "express": "^4.21.1",
    "cors": "^2.8.5",
    "helmet": "^8.0.0",
    "dotenv": "^16.4.5",
    "express-rate-limit": "^7.4.1",
    "pg": "^8.13.1",
    "jsonwebtoken": "^9.0.2",
    "bcrypt": "^5.1.1",
    "swagger-ui-express": "^5.0.1",
    "swagger-jsdoc": "^6.2.8"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "ts-node-dev": "^2.0.0",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/bcrypt": "^5.0.2",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/swagger-jsdoc": "^6.0.4"
  }
}
